# =============================================================================
# PureClaw / NEXUS — Engine Configuration
# =============================================================================
# Eight engines: Ollama (local, default), vLLM, Anthropic API, AWS Bedrock,
# Claude Code, Codex, Gemini, or Hybrid (API + CLI).
# One env var to switch:
ENGINE_BACKEND=ollama

# Telegram bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
AUTHORIZED_USER_ID=your-telegram-user-id

# Agent Identity — name your agent and give it a personality
# AGENT_NAME=HAL
# AGENT_PERSONALITY=You speak like HAL 9000 from 2001: A Space Odyssey — calm, measured, precise, subtly unsettling. Polite but never warm.

# =============================================================================
# Ollama — local models (default)
# =============================================================================
# Any GGUF model via Ollama, with tool use. This is the default.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:235b
# OLLAMA_TOOLS_ENABLED=true
# OLLAMA_TOOL_MAX_ITER=25
# OLLAMA_TOOL_TIMEOUT=30
# OLLAMA_NUM_PREDICT=8192

# Web search — SearXNG (self-hosted, private) or DuckDuckGo (default, zero config)
# If set, web_search tool uses your SearXNG instance. If empty, falls back to DuckDuckGo.
# SEARXNG_URL=http://localhost:8080/search

# =============================================================================
# vLLM — local OpenAI-compatible endpoint
# =============================================================================
# Any model served by vLLM with tool use support.
# ENGINE_BACKEND=vllm
# VLLM_URL=http://localhost:8200/v1
# VLLM_MODEL=your-model-name
# VLLM_TOOLS_ENABLED=true
# VLLM_TOOL_MAX_ITER=10
# VLLM_TOOL_TIMEOUT=60
# VLLM_TOTAL_TIMEOUT=300
# VLLM_MAX_TOKENS=8192

# =============================================================================
# Anthropic API (direct)
# =============================================================================
# ENGINE_BACKEND=anthropic_api
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MAX_TOKENS=4096
# ANTHROPIC_TOOLS_ENABLED=true
# ANTHROPIC_TOOL_MAX_ITER=25
# ANTHROPIC_TOOL_TIMEOUT=120
# ANTHROPIC_TOTAL_TIMEOUT=600

# =============================================================================
# AWS Bedrock — Claude via AWS
# =============================================================================
# Uses standard AWS credential chain (~/.aws/credentials, env vars, IAM role).
# ENGINE_BACKEND=bedrock_api
# AWS_DEFAULT_REGION=us-east-1
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
# BEDROCK_MAX_TOKENS=64000

# =============================================================================
# Claude Code CLI (Anthropic)
# =============================================================================
# CLAUDE_BIN=/usr/bin/claude
# CLAUDE_CWD=/home/user
CLAUDE_TIMEOUT=1800
# CLAUDE_MODEL=sonnet

# =============================================================================
# Codex CLI (OpenAI)
# =============================================================================
# CODEX_BIN=/usr/bin/codex
# CODEX_MODEL=gpt-5.2-codex
# CODEX_CWD=/home/user
# OPENAI_API_KEY=sk-proj-...

# =============================================================================
# Gemini CLI (Google)
# =============================================================================
# GEMINI_BIN=/usr/bin/gemini
# GEMINI_CLI_MODEL=gemini-2.5-flash

# =============================================================================
# Hybrid — routes between API (fast) and CLI (power)
# =============================================================================
# ENGINE_BACKEND=hybrid
# HYBRID_DEFAULT=api
# HYBRID_CLI_TIMEOUT=1800
# HYBRID_API_TIMEOUT=300

# =============================================================================
# Discord
# =============================================================================
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_AUTHORIZED_USER_ID=your-discord-user-id

# =============================================================================
# Subagent parallelism
# =============================================================================
# SUBAGENT_MODEL=sonnet
# SUBAGENT_MAX_ITER=15
# SUBAGENT_TIMEOUT=180

# =============================================================================
# Context compression
# =============================================================================
# COMPRESS_TRIGGER_TOKENS=100000
# PRESERVE_RECENT_MESSAGES=40
# SUMMARY_MODEL=us.anthropic.claude-haiku-4-5-20251001

# =============================================================================
# Dispatcher — instant data cards (no engine needed)
# =============================================================================
WEATHER_DEFAULT_LOCATION=Windsor,UK
PROMETHEUS_URL=http://your-prometheus-host:9090
DARWIN_API_TOKEN=
GOLD_API_KEY=

# =============================================================================
# Voice
# =============================================================================
# WHISPER_URL=http://127.0.0.1:9000/transcribe

# =============================================================================
# Daily Intelligence Snippet — email delivery
# =============================================================================
SNIPPET_SMTP_HOST=
SNIPPET_SMTP_PORT=587
SNIPPET_SMTP_USER=
SNIPPET_SMTP_PASS=
SNIPPET_FROM=
SNIPPET_TO=

# =============================================================================
# Alerts — separate bot for observer alerts (defaults to main bot)
# =============================================================================
# ALERT_BOT_TOKEN=your-alert-bot-token
