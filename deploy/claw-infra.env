# Claw-Infra — tensor-core infrastructure specialist
CLAW_ID=infra
CLAW_PORT=9880
CLAW_AUTHORITY_LEVEL=auto_fix
CLAW_MESH_PEERS={"prime":"http://100.103.248.9:30876","ops":"http://10.200.0.1:9880","sentinel":"http://100.80.213.1:9880"}

# Engine — local vLLM (zero internet dependency)
ENGINE_BACKEND=vllm
VLLM_URL=http://127.0.0.1:5000/v1
VLLM_MODEL=nvidia/nemotron-3-super
VLLM_TOOLS_ENABLED=true
VLLM_TOOL_MAX_ITER=10
VLLM_TOOL_TIMEOUT=60
VLLM_TOTAL_TIMEOUT=300
VLLM_MAX_TOKENS=16384

# Failover — Bedrock if local vLLM is somehow down
FAILOVER_ENABLED=true
FAILOVER_BACKEND=bedrock_api

# Agent identity
AGENT_NAME=Claw-Infra

# System prompt
SYSTEM_PROMPT_PATH=/home/puretensorai/nexus/prompts/claw_infra_prompt.md

# Security policy
SECURITY_POLICY_PATH=/home/puretensorai/nexus/security/claw_infra_policy.yaml

# Telegram (for escalation alerts)
TELEGRAM_BOT_TOKEN=SET_ME
AUTHORIZED_USER_ID=22276981
ALERT_BOT_TOKEN=SET_ME
