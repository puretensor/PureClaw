# Claw-Ops — fox-n0 storage/compute specialist
CLAW_ID=ops
CLAW_PORT=9880
CLAW_AUTHORITY_LEVEL=auto_fix
CLAW_MESH_PEERS={"prime":"http://100.103.248.9:30876","infra":"http://10.200.0.3:9880","sentinel":"http://100.80.213.1:9880"}

# Engine — vLLM on tensor-core via 200G fabric
ENGINE_BACKEND=vllm
VLLM_URL=http://10.200.0.3:5000/v1
VLLM_MODEL=nvidia/nemotron-3-super
VLLM_TOOLS_ENABLED=true
VLLM_TOOL_MAX_ITER=10
VLLM_TOOL_TIMEOUT=60
VLLM_TOTAL_TIMEOUT=300
VLLM_MAX_TOKENS=16384

# Failover — Bedrock if TC is offline
FAILOVER_ENABLED=true
FAILOVER_BACKEND=bedrock_api

# Agent identity
AGENT_NAME=Claw-Ops

# System prompt
SYSTEM_PROMPT_PATH=/opt/claw-ops/prompts/claw_ops_prompt.md

# Security policy
SECURITY_POLICY_PATH=/opt/claw-ops/security/claw_ops_policy.yaml

# Telegram (for escalation alerts)
TELEGRAM_BOT_TOKEN=SET_ME
AUTHORIZED_USER_ID=22276981
ALERT_BOT_TOKEN=SET_ME
