# Claw-Sentinel — mon2 alert triage watchdog
CLAW_ID=sentinel
CLAW_PORT=9880
CLAW_AUTHORITY_LEVEL=alert_only
CLAW_MESH_PEERS={"prime":"http://<TS_FOX_N1>:30876","infra":"http://<TS_TENSOR_CORE>:9880","ops":"http://<TS_FOX_N0>:9880"}

# Engine — Gemini Flash (lightweight cloud LLM for classification)
ENGINE_BACKEND=gemini_api
GEMINI_MODEL=gemini-3-flash-preview

# Failover — Bedrock
FAILOVER_ENABLED=true
FAILOVER_BACKEND=bedrock_api

# Agent identity
AGENT_NAME=Claw-Sentinel

# System prompt
SYSTEM_PROMPT_PATH=/opt/claw-sentinel/prompts/claw_sentinel_prompt.md

# Security policy
SECURITY_POLICY_PATH=/opt/claw-sentinel/security/claw_sentinel_policy.yaml

# Monitoring endpoints (local to mon2)
PROMETHEUS_URL=http://127.0.0.1:9090
ALERTMANAGER_URL=http://127.0.0.1:9093

# Telegram (for escalation alerts)
TELEGRAM_BOT_TOKEN=SET_ME
AUTHORIZED_USER_ID=<TELEGRAM_CHAT_ID>
ALERT_BOT_TOKEN=SET_ME
